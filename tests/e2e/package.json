{
  "name": "enterprise-asset-monitoring-e2e",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "npm run test:api:smoke && npm run test:ui",
    "test:api": "npm run test:api:smoke",
    "test:api:smoke": "vitest run api/auth.e2e.test.js api/notification-flow.e2e.test.js",
    "test:api:deep": "vitest run api/experimental/monitoring-flow.e2e.test.js api/experimental/incident-flow.e2e.test.js api/experimental/sla-flow.e2e.test.js",
    "test:api:watch": "vitest api",
    "test:ui": "playwright test --config=ui/playwright.config.js",
    "test:ui:headed": "playwright test --config=ui/playwright.config.js --headed",
    "test:ui:debug": "playwright test --config=ui/playwright.config.js --debug",
    "test:sla:slow": "vitest run api/sla-breach.e2e.test.js"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "axios": "latest",
    "vitest": "latest"
  }
}
